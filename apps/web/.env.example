# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app_template"

# Better Auth
BETTER_AUTH_SECRET="your-secret-key-here-change-in-production-minimum-32-characters"
BETTER_AUTH_URL="http://localhost:3000"

# Optional: Session configuration (in seconds)
# SESSION_EXPIRES_IN=604800  # 7 days (default)
# SESSION_UPDATE_AGE=86400   # 1 day (default)

# Logging
LOG_LEVEL=debug

# Sentry (optional - errors are not reported when unset)
VITE_SENTRY_DSN=           # Public DSN (exposed to browser via Vite)
SENTRY_DSN=                # Same DSN value for server-side
SENTRY_AUTH_TOKEN=         # For source map uploads (build/CI only, not runtime)
SENTRY_ORG=                # Sentry org slug (build/CI only)
SENTRY_PROJECT=            # Sentry project slug (build/CI only)

# Email (Resend - optional, emails are logged to console when unset)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com
